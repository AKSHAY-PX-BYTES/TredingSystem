FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY ["src/TradingSystem.Web/TradingSystem.Web.csproj", "TradingSystem.Web/"]
RUN dotnet restore "TradingSystem.Web/TradingSystem.Web.csproj"
COPY src/TradingSystem.Web/ TradingSystem.Web/
WORKDIR "/src/TradingSystem.Web"
RUN dotnet build "TradingSystem.Web.csproj" -c Release -o /app/build
RUN dotnet publish "TradingSystem.Web.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM nginx:alpine AS final
COPY --from=build /app/publish/wwwroot /usr/share/nginx/html
COPY nginx.conf /etc/nginx/nginx.conf
EXPOSE 80
