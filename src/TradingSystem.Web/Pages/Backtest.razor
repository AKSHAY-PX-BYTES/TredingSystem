@page "/backtest"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@implements IDisposable
@inject IBacktestApiService BacktestApi
@inject ICurrencyService Currency
@inject IJSRuntime JS

<FeatureGate FeatureKey="backtest">
<PageTitle>Backtesting - AI Trading System</PageTitle>

<div class="page-header">
    <h1>🧪 Strategy Backtesting</h1>
    <p>Simulate trading strategies on historical data</p>
</div>

<!-- Configuration -->
<div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
        <h3>⚙️ Backtest Configuration</h3>
    </div>
    <div class="grid grid-4">
        <div class="form-group">
            <label class="form-label">Stock Symbol</label>
            <input class="form-input" @bind="request.Symbol" placeholder="AAPL" />
        </div>
        <div class="form-group">
            <label class="form-label">Period (Days)</label>
            <input type="number" class="form-input" @bind="request.Days" min="10" max="365" />
        </div>
        <div class="form-group">
            <label class="form-label">Initial Capital (USD)</label>
            <input type="number" class="form-input" @bind="request.InitialCapital" min="1000" step="1000" />
        </div>
        <div class="form-group">
            <label class="form-label">Strategy</label>
            <select class="form-select" @bind="request.Strategy">
                <option value="Combined">Combined (Technical + Sentiment)</option>
                <option value="TechnicalOnly">Technical Only</option>
                <option value="SentimentOnly">Sentiment / Momentum</option>
            </select>
        </div>
    </div>
    <div style="display:flex; gap:0.5rem; margin-top:0.5rem;">
        <button class="btn btn-primary btn-lg" @onclick="RunBacktest" disabled="@isRunning">
            @if (isRunning)
            {
                <span class="loading-spinner" style="width:16px;height:16px;border-width:2px;"></span>
            }
            🚀 Run Backtest
        </button>
        <div class="symbol-selector" style="margin-left:1rem;">
            @foreach (var s in new[] { "AAPL", "MSFT", "TSLA", "NVDA", "GOOGL" })
            {
                <button class="symbol-chip @(s == request.Symbol.ToUpper() ? "active" : "")"
                        @onclick="() => { request.Symbol = s; }">@s</button>
            }
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="error-container fade-in" style="margin-bottom:1.5rem;">
        <p>⚠️ @error</p>
    </div>
}

@if (result != null)
{
    <!-- Summary Stats -->
    <div class="grid grid-4 fade-in" style="margin-bottom: 1.5rem;">
        <div class="stat-card">
            <div class="stat-label">Total Return</div>
            <div class="stat-value @(result.TotalReturn >= 0 ? "sentiment-positive" : "sentiment-negative")">
                @(result.TotalReturn >= 0 ? "+" : "")@Currency.FormatPrice(result.TotalReturn)
            </div>
            <div class="stat-change @(result.TotalReturnPercent >= 0 ? "positive" : "negative")">
                @(result.TotalReturnPercent >= 0 ? "▲" : "▼") @Math.Abs(result.TotalReturnPercent).ToString("N2")%
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Final Capital</div>
            <div class="stat-value">@Currency.FormatPrice(result.FinalCapital)</div>
            <div class="stat-change neutral">Initial: @Currency.FormatPrice(result.InitialCapital)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Win Rate</div>
            <div class="stat-value @(result.WinRate >= 50 ? "sentiment-positive" : "sentiment-negative")">
                @result.WinRate.ToString("N1")%
            </div>
            <div class="stat-change neutral">@result.WinningTrades W / @result.LosingTrades L</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Sharpe Ratio</div>
            <div class="stat-value @(result.SharpeRatio >= 1 ? "sentiment-positive" : result.SharpeRatio >= 0 ? "sentiment-neutral" : "sentiment-negative")">
                @result.SharpeRatio.ToString("N3")
            </div>
            <div class="stat-change neutral">Max Drawdown: @result.MaxDrawdown.ToString("N2")%</div>
        </div>
    </div>

    <!-- Charts -->
    <div class="grid grid-2 fade-in" style="margin-bottom: 1.5rem;">
        <div class="card">
            <div class="card-header">
                <h3>💰 Equity Curve</h3>
            </div>
            <div class="chart-container tall">
                <canvas id="equityChart"></canvas>
            </div>
        </div>
        <div class="card">
            <div class="card-header">
                <h3>📊 Trade P&L</h3>
            </div>
            <div class="chart-container tall">
                <canvas id="pnlChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Additional Stats -->
    <div class="grid grid-3 fade-in" style="margin-bottom: 1.5rem;">
        <div class="stat-card">
            <div class="stat-label">Total Trades</div>
            <div class="stat-value">@result.TotalTrades</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Period</div>
            <div class="stat-value" style="font-size:1rem;">@result.StartDate.ToString("MMM dd") — @result.EndDate.ToString("MMM dd, yyyy")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Strategy Used</div>
            <div class="stat-value" style="font-size:1rem;">@result.Strategy</div>
        </div>
    </div>

    <!-- Trades Table -->
    <div class="card fade-in">
        <div class="card-header">
            <h3>📋 Trade History</h3>
            <span style="font-size:0.8rem; color:var(--text-muted);">@result.Trades.Count trades executed</span>
        </div>
        @if (result.Trades.Any())
        {
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Entry Date</th>
                            <th>Exit Date</th>
                            <th>Type</th>
                            <th>Entry Price</th>
                            <th>Exit Price</th>
                            <th>P&L (@Currency.CurrentCurrencyCode)</th>
                            <th>P&L (%)</th>
                            <th>Portfolio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trade in result.Trades)
                        {
                            <tr>
                                <td>@trade.TradeNumber</td>
                                <td>@trade.EntryDate.ToString("MMM dd")</td>
                                <td>@(trade.ExitDate?.ToString("MMM dd") ?? "—")</td>
                                <td><span class="signal-badge signal-hold">@trade.Signal</span></td>
                                <td>@Currency.FormatPrice(trade.EntryPrice)</td>
                                <td>@(trade.ExitPrice.HasValue ? Currency.FormatPrice(trade.ExitPrice.Value) : "—")</td>
                                <td class="@(trade.ProfitLoss >= 0 ? "sentiment-positive" : "sentiment-negative")">
                                    @(trade.ProfitLoss >= 0 ? "+" : "")@(trade.ProfitLoss.HasValue ? Currency.FormatPrice(trade.ProfitLoss.Value) : "—")
                                </td>
                                <td class="@(trade.ProfitLossPercent >= 0 ? "sentiment-positive" : "sentiment-negative")">
                                    @(trade.ProfitLossPercent >= 0 ? "+" : "")@(trade.ProfitLossPercent?.ToString("N2") ?? "—")%
                                </td>
                                <td>@Currency.FormatPrice(trade.PortfolioValue)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="loading-container">
                <p>No trades were executed during this period.</p>
            </div>
        }
    </div>
}
</FeatureGate>

@code {
    private BacktestRequest request = new()
    {
        Symbol = "AAPL",
        Days = 60,
        InitialCapital = 10000,
        Strategy = "Combined"
    };

    private bool isRunning = false;
    private string? error;
    private BacktestResult? result;

    protected override void OnInitialized()
    {
        Currency.OnCurrencyChanged += OnCurrencyChanged;
    }

    private void OnCurrencyChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task RunBacktest()
    {
        if (string.IsNullOrWhiteSpace(request.Symbol))
        {
            error = "Please enter a stock symbol.";
            return;
        }

        isRunning = true;
        error = null;
        result = null;
        StateHasChanged();

        try
        {
            result = await BacktestApi.RunAsync(request);
            StateHasChanged();

            await Task.Delay(100);
            await RenderCharts();
        }
        catch (Exception ex)
        {
            error = $"Backtest failed: {ex.Message}";
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }

    private async Task RenderCharts()
    {
        if (result == null) return;

        // Equity Curve
        if (result.EquityCurve.Any())
        {
            var eqLabels = result.EquityCurve
                .Where((_, i) => i % Math.Max(1, result.EquityCurve.Count / 30) == 0)
                .Select(e => e.Date.ToString("MMM dd")).ToArray();
            var eqValues = result.EquityCurve
                .Where((_, i) => i % Math.Max(1, result.EquityCurve.Count / 30) == 0)
                .Select(e => (double)e.Value).ToArray();

            var datasets = new[]
            {
                new { label = "Portfolio Value", data = eqValues, color = "rgb(59, 130, 246)", fill = true, pointRadius = 0 }
            };

            await JS.InvokeVoidAsync("chartInterop.createLineChart", "equityChart", eqLabels, datasets, "Equity Curve");
        }

        // P&L Bar Chart
        if (result.Trades.Any())
        {
            var tradeLabels = result.Trades.Select(t => $"#{t.TradeNumber}").ToArray();
            var pnlValues = result.Trades.Select(t => (double)(t.ProfitLoss ?? 0)).ToArray();

            await JS.InvokeVoidAsync("chartInterop.createBarChart", "pnlChart", tradeLabels, pnlValues, $"Trade P&L ({Currency.CurrentCurrencyCode})", (object?)null);
        }
    }

    public void Dispose()
    {
        Currency.OnCurrencyChanged -= OnCurrencyChanged;
    }
}
