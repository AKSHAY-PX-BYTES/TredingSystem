@page "/reset-password"
@layout LoginLayout
@using TradingSystem.Web.Models
@using TradingSystem.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Reset Password - Trading System</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">
                <span class="logo-icon">🔐</span>
                <h1>Reset Password</h1>
                <p class="login-subtitle">Set your new password</p>
            </div>
        </div>

        <div class="login-body">
            @if (resetComplete)
            {
                <div class="pwd-success" style="text-align: center; padding: 2rem 1rem;">
                    <span style="font-size: 3rem; display: block; margin-bottom: 1rem;">✅</span>
                    <h3 style="margin-bottom: 0.5rem;">Password Reset Successful!</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">@successMessage</p>
                    <a href="/login" class="login-btn" style="display: inline-flex; text-decoration: none;">
                        🔐 Go to Login
                    </a>
                </div>
            }
            else if (isInvalidLink)
            {
                <div class="login-error" style="text-align: center; padding: 2rem 1rem;">
                    <span style="font-size: 3rem; display: block; margin-bottom: 1rem;">⚠️</span>
                    <h3 style="margin-bottom: 0.5rem;">Invalid Reset Link</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">This link is missing required parameters. Please request a new reset link.</p>
                    <a href="/login" class="login-btn" style="display: inline-flex; text-decoration: none;">
                        ← Back to Login
                    </a>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="login-error">
                        <span class="error-icon">⚠️</span>
                        <span>@errorMessage</span>
                    </div>
                }

                <div class="form-group">
                    <label><span class="field-icon">✉️</span> Email</label>
                    <input type="email" class="form-input" value="@email" disabled />
                </div>

                <div class="form-group">
                    <label><span class="field-icon">🔒</span> New Password</label>
                    <div class="password-wrapper">
                        <input type="@(showPassword ? "text" : "password")"
                               class="form-input" @bind="newPassword" @bind:event="oninput"
                               placeholder="Enter new password (min 6 characters)" disabled="@isLoading" />
                        <button type="button" class="toggle-password" @onclick="() => showPassword = !showPassword">
                            @(showPassword ? "🙈" : "👁️")
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label><span class="field-icon">🔒</span> Confirm Password</label>
                    <div class="password-wrapper">
                        <input type="@(showConfirm ? "text" : "password")"
                               class="form-input" @bind="confirmPassword" @bind:event="oninput"
                               placeholder="Confirm new password" disabled="@isLoading" />
                        <button type="button" class="toggle-password" @onclick="() => showConfirm = !showConfirm">
                            @(showConfirm ? "🙈" : "👁️")
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(confirmPassword) && newPassword != confirmPassword)
                    {
                        <span class="field-msg field-error">Passwords do not match</span>
                    }
                </div>

                <button type="button" class="login-btn" @onclick="HandleResetPassword"
                        disabled="@(isLoading || string.IsNullOrWhiteSpace(newPassword) || newPassword != confirmPassword || newPassword.Length < 6)">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <span>🔐 Set New Password</span>
                    }
                </button>

                <div style="text-align: center; margin-top: 1.5rem;">
                    <a href="/login" style="color: var(--text-muted); font-size: 0.85rem;">← Back to Login</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string token = string.Empty;
    private string email = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;
    private bool showPassword;
    private bool showConfirm;
    private bool resetComplete;
    private bool isInvalidLink;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        token = query["token"] ?? string.Empty;
        email = query["email"] ?? string.Empty;

        if (string.IsNullOrEmpty(token) || string.IsNullOrEmpty(email))
        {
            isInvalidLink = true;
        }
    }

    private async Task HandleResetPassword()
    {
        errorMessage = null;

        if (newPassword.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var request = new ResetPasswordRequest
            {
                Token = token,
                Email = email,
                NewPassword = newPassword,
                ConfirmPassword = confirmPassword
            };

            var result = await AuthService.ResetPasswordAsync(request);

            if (result.Success)
            {
                resetComplete = true;
                successMessage = result.Message ?? "Password reset successfully!";
            }
            else
            {
                errorMessage = result.Error ?? "Failed to reset password. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
