@page "/register"
@layout LoginLayout
@using TradingSystem.Web.Models
@using TradingSystem.Web.Services
@inject IAuthService AuthService
@inject IFeatureFlagService FeatureFlagService
@inject NavigationManager Navigation

<FeatureGate FeatureKey="signup">
<PageTitle>Sign Up - Trading System</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">
                <span class="logo-icon">📈</span>
                <h1>Trading System</h1>
                <p class="login-subtitle">Create Your Account</p>
            </div>
        </div>

        <div class="login-body">
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="login-success">
                    <span class="success-icon">✅</span>
                    <span>@successMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="login-error">
                    <span class="error-icon">⚠️</span>
                    <span>@errorMessage</span>
                </div>
            }

            @if (registrationStep == 1)
            {
                <!-- Step 1: Email Verification -->
                <div class="form-section">
                    <h3 style="text-align: center; margin-bottom: 1rem;">📧 Step 1: Verify Email</h3>
                    <div class="form-group">
                        <label for="email">
                            <span class="field-icon">📧</span> Email Address
                        </label>
                        <InputText id="email" @bind-Value="registerModel.Email"
                                   class="form-input" placeholder="Enter your email"
                                   disabled="@isLoading" />
                        <ValidationMessage For="@(() => registerModel.Email)" class="validation-msg" />
                    </div>

                    <button type="button" class="login-btn" @onclick="SendOtp" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>📧 Send OTP</span>
                        }
                    </button>
                </div>
            }
            else if (registrationStep == 2)
            {
                <!-- Step 2: OTP Verification -->
                <div class="form-section">
                    <h3 style="text-align: center; margin-bottom: 1rem;">🔐 Step 2: Verify OTP</h3>
                    <p style="text-align: center; color: var(--text-muted); margin-bottom: 1.5rem;">
                        We've sent a 6-digit code to <strong>@registerModel.Email</strong>
                    </p>
                    
                    <div class="form-group">
                        <label for="otp">
                            <span class="field-icon">�</span> OTP Code
                        </label>
                        <input id="otp" type="text" @bind="otpCode" @bind:event="oninput"
                               class="form-input" placeholder="Enter 6-digit code"
                               maxlength="6" pattern="[0-9]*" disabled="@isLoading"
                               style="font-size: 1.5rem; letter-spacing: 0.5rem; text-align: center;" />
                    </div>

                    <button type="button" class="login-btn" @onclick="VerifyOtp" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                            <span>Verifying...</span>
                        }
                        else
                        {
                            <span>✅ Verify OTP</span>
                        }
                    </button>

                    <button type="button" class="login-btn" @onclick="() => registrationStep = 1" 
                            disabled="@isLoading" style="background-color: var(--text-muted); margin-top: 0.5rem;">
                        ← Back
                    </button>
                </div>
            }
            else if (registrationStep == 3)
            {
                <!-- Step 3: Choose Plan -->
                <div class="form-section">
                    <h3 style="text-align: center; margin-bottom: 0.5rem;">🏷️ Step 3: Choose Your Plan</h3>
                    <p style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">
                        Select a plan to get started. You can upgrade anytime.
                    </p>

                    <div class="plan-selection-grid">
                        @foreach (var plan in availablePlans)
                        {
                            <div class="plan-select-card @(registerModel.Plan == plan.Name ? "plan-selected" : "") @(plan.Name.ToLower())-plan"
                                 @onclick="() => registerModel.Plan = plan.Name">
                                <div class="plan-select-badge-wrap">
                                    <span class="plan-badge-icon plan-badge-@(plan.Name.ToLower())">@plan.Icon</span>
                                </div>
                                <div class="plan-select-name">@plan.Name</div>
                                <div class="plan-select-price">
                                    @if (plan.Price == 0)
                                    {
                                        <span class="plan-price-free">Free</span>
                                    }
                                    else
                                    {
                                        <span class="plan-price-amount">$@plan.Price</span><span class="plan-price-period">/mo</span>
                                    }
                                </div>
                                <ul class="plan-select-features">
                                    @foreach (var feature in plan.Highlights)
                                    {
                                        <li>✓ @feature</li>
                                    }
                                </ul>
                                @if (registerModel.Plan == plan.Name)
                                {
                                    <div class="plan-check-mark">✅ Selected</div>
                                }
                            </div>
                        }
                    </div>

                    <button type="button" class="login-btn" @onclick="() => registrationStep = 4" 
                            disabled="@(string.IsNullOrEmpty(registerModel.Plan))" style="margin-top: 1rem;">
                        Continue →
                    </button>
                    <button type="button" class="login-btn" @onclick="() => { registrationStep = 2; errorMessage = null; }"
                            disabled="@isLoading" style="background-color: var(--text-muted); margin-top: 0.5rem;">
                        ← Back
                    </button>
                </div>
            }
            else if (registrationStep == 4)
            {
                <!-- Step 4: Account Details -->
                <div class="form-section">
                    <h3 style="text-align: center; margin-bottom: 1rem;">👤 Step 4: Account Details</h3>
                    
                    <div class="login-form">
                        <div class="form-group">
                            <label for="username">
                                <span class="field-icon">👤</span> Username
                            </label>
                            <div class="username-wrapper">
                                <input id="username" type="text" @bind="registerModel.Username" @bind:event="oninput"
                                       @onfocusout="CheckUsername"
                                       class="form-input @usernameInputClass" placeholder="Choose a username (min 3 chars)"
                                       disabled="@isLoading" />
                                @if (isCheckingUsername)
                                {
                                    <span class="username-status checking">⏳</span>
                                }
                                else if (usernameValid == true)
                                {
                                    <span class="username-status valid">✅</span>
                                }
                                else if (usernameValid == false)
                                {
                                    <span class="username-status invalid">❌</span>
                                }
                            </div>
                            @if (usernameValid == false && !string.IsNullOrEmpty(usernameMessage))
                            {
                                <div class="field-msg field-error">@usernameMessage</div>
                            }
                            @if (usernameValid == true)
                            {
                                <div class="field-msg field-success">@usernameMessage</div>
                            }
                        </div>

                        <div class="form-group @(usernameValid != true ? "field-locked" : "")">
                            <label for="password">
                                <span class="field-icon">🔒</span> Password
                                @if (usernameValid != true)
                                {
                                    <span class="lock-hint">— Choose a valid username first</span>
                                }
                            </label>
                            <div class="password-wrapper">
                                <input id="password" type="@(showPassword ? "text" : "password")"
                                       @bind="registerModel.Password" @bind:event="oninput"
                                       class="form-input" placeholder="Create a password"
                                       disabled="@(isLoading || usernameValid != true)" />
                                <button type="button" class="toggle-password" @onclick="TogglePassword" 
                                        tabindex="-1" disabled="@(usernameValid != true)">
                                    @(showPassword ? "🙈" : "👁️")
                                </button>
                            </div>

                            @if (usernameValid == true && !string.IsNullOrWhiteSpace(registerModel.Password))
                            {
                                <div class="pwd-policy">
                                    <div class="pwd-policy-title">Password must contain:</div>
                                    <div class="pwd-rule @(RegHasMinLength ? "pass" : "fail")">
                                        <span class="pwd-icon">@(RegHasMinLength ? "✅" : "❌")</span> At least 8 characters
                                    </div>
                                    <div class="pwd-rule @(RegHasLowercase ? "pass" : "fail")">
                                        <span class="pwd-icon">@(RegHasLowercase ? "✅" : "❌")</span> Lower case letters (a-z)
                                    </div>
                                    <div class="pwd-rule @(RegHasUppercase ? "pass" : "fail")">
                                        <span class="pwd-icon">@(RegHasUppercase ? "✅" : "❌")</span> Upper case letters (A-Z)
                                    </div>
                                    <div class="pwd-rule @(RegHasDigit ? "pass" : "fail")">
                                        <span class="pwd-icon">@(RegHasDigit ? "✅" : "❌")</span> Numbers (0-9)
                                    </div>
                                    <div class="pwd-rule @(RegHasSpecial ? "pass" : "fail")">
                                        <span class="pwd-icon">@(RegHasSpecial ? "✅" : "❌")</span> Special characters (e.g. !@@#$%^&amp;)
                                    </div>
                                    <div class="pwd-rule @(RegNoRepeatingChars ? "pass" : "fail")">
                                        <span class="pwd-icon">@(RegNoRepeatingChars ? "✅" : "❌")</span> No more than 2 identical characters in a row
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="form-group @(usernameValid != true || !RegAllRulesPass ? "field-locked" : "")">
                            <label for="confirmPassword">
                                <span class="field-icon">🔒</span> Confirm Password
                            </label>
                            <div class="password-wrapper">
                                <input id="confirmPassword" type="@(showConfirmPassword ? "text" : "password")"
                                       @bind="registerModel.ConfirmPassword" @bind:event="oninput"
                                       class="form-input" placeholder="Confirm your password"
                                       disabled="@(isLoading || usernameValid != true || !RegAllRulesPass)" />
                                <button type="button" class="toggle-password" @onclick="ToggleConfirmPassword" tabindex="-1">
                                    @(showConfirmPassword ? "🙈" : "👁️")
                                </button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(registerModel.ConfirmPassword))
                            {
                                <div class="field-msg @(registerModel.Password == registerModel.ConfirmPassword ? "field-success" : "field-error")">
                                    @(registerModel.Password == registerModel.ConfirmPassword ? "✅ Passwords match" : "❌ Passwords do not match")
                                </div>
                            }
                        </div>

                        <button type="button" class="login-btn" @onclick="HandleRegister" disabled="@(!RegCanSubmit)">
                            @if (isLoading)
                            {
                                <span class="spinner"></span>
                                <span>Creating account...</span>
                            }
                            else
                            {
                                <span>📝 Complete Sign Up</span>
                            }
                        </button>
                    </div>

                    <button type="button" class="login-btn" @onclick="() => { registrationStep = 3; errorMessage = null; }" 
                            disabled="@isLoading" style="background-color: var(--text-muted); margin-top: 0.5rem;">
                        ← Back
                    </button>
                </div>
            }

            <div class="register-link" style="text-align: center; margin-top: 1.5rem;">
                <span style="color: var(--text-muted);">Already have an account?</span>
                <a href="/login" style="color: var(--groww-green); font-weight: 600; margin-left: 0.5rem;">Sign In</a>
            </div>
        </div>

        <div class="login-footer">
            <p>© 2026 Trading System • Powered by AI & ML.NET</p>
        </div>
    </div>

    <div class="login-features">
        <div class="feature-item">
            <span class="feature-icon">🤖</span>
            <div class="feature-text">
                <strong>AI-Powered Analysis</strong>
                <span>Get intelligent trading insights</span>
            </div>
        </div>
        <div class="feature-item">
            <span class="feature-icon">📊</span>
            <div class="feature-text">
                <strong>Live Market Data</strong>
                <span>Real-time stock prices from Yahoo Finance</span>
            </div>
        </div>
        <div class="feature-item">
            <span class="feature-icon">🔐</span>
            <div class="feature-text">
                <strong>Secure & Private</strong>
                <span>Your data is encrypted and protected</span>
            </div>
        </div>
    </div>
</div>
</FeatureGate>


@code {
    private RegisterRequest registerModel = new();
    private bool isLoading = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private string? errorMessage;
    private string? successMessage;
    private int registrationStep = 1; // 1: Email, 2: OTP, 3: Choose Plan, 4: Account Details
    private string otpCode = string.Empty;

    // Plan options
    private readonly List<PlanOption> availablePlans = new()
    {
        new PlanOption { Name = "Basic", Icon = "🆓", Price = 0, Highlights = new[] { "Real-time market data", "Basic charts & indicators", "Watchlist (up to 10)", "Daily news digest" } },
        new PlanOption { Name = "Pro", Icon = "⚡", Price = 29, Highlights = new[] { "Everything in Basic", "Advanced AI predictions", "Unlimited watchlists", "Backtesting engine", "Priority support" } },
        new PlanOption { Name = "Super", Icon = "👑", Price = 79, Highlights = new[] { "Everything in Pro", "Real-time AI signals", "Portfolio analytics", "API access", "Dedicated account manager" } }
    };

    private class PlanOption
    {
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "";
        public decimal Price { get; set; }
        public string[] Highlights { get; set; } = Array.Empty<string>();
    }

    // Username validation
    private bool? usernameValid = null;
    private string usernameMessage = "";
    private bool isCheckingUsername = false;
    private string lastCheckedUsername = "";
    private string usernameInputClass => usernameValid == true ? "input-valid" : usernameValid == false ? "input-invalid" : "";

    // Password policy
    private bool RegHasMinLength => (registerModel.Password?.Length ?? 0) >= 8;
    private bool RegHasLowercase => System.Text.RegularExpressions.Regex.IsMatch(registerModel.Password ?? "", "[a-z]");
    private bool RegHasUppercase => System.Text.RegularExpressions.Regex.IsMatch(registerModel.Password ?? "", "[A-Z]");
    private bool RegHasDigit => System.Text.RegularExpressions.Regex.IsMatch(registerModel.Password ?? "", "[0-9]");
    private bool RegHasSpecial => System.Text.RegularExpressions.Regex.IsMatch(registerModel.Password ?? "", @"[!@#$%^&*()_+\-=\[\]{};':""\\|,.<>\/?]");
    private bool RegNoRepeatingChars => !HasThreeConsecutiveIdentical(registerModel.Password ?? "");
    private bool RegAllRulesPass => RegHasMinLength && RegHasLowercase && RegHasUppercase && RegHasDigit && RegHasSpecial && RegNoRepeatingChars;
    private bool RegCanSubmit => usernameValid == true && RegAllRulesPass
        && !string.IsNullOrWhiteSpace(registerModel.ConfirmPassword)
        && registerModel.Password == registerModel.ConfirmPassword && !isLoading;

    private static bool HasThreeConsecutiveIdentical(string s)
    {
        for (int i = 2; i < s.Length; i++)
            if (s[i] == s[i - 1] && s[i] == s[i - 2]) return true;
        return false;
    }

    private async Task SendOtp()
    {
        errorMessage = null;
        
        if (string.IsNullOrWhiteSpace(registerModel.Email))
        {
            errorMessage = "Email is required";
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await AuthService.SendOtpAsync(registerModel.Email);
            
            if (response?.Success == true)
            {
                registrationStep = 2;
                otpCode = string.Empty;
            }
            else
            {
                errorMessage = response?.Error ?? "Failed to send OTP";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task VerifyOtp()
    {
        errorMessage = null;
        otpCode = otpCode?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(otpCode) || otpCode.Length != 6)
        {
            errorMessage = "OTP must be 6 digits";
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await AuthService.VerifyOtpAsync(registerModel.Email, otpCode);
            
            if (response?.Success == true)
            {
                registrationStep = 3;
            }
            else
            {
                errorMessage = response?.Error ?? "Failed to verify OTP";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleRegister()
    {
        if (!RegCanSubmit) return;

        isLoading = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            var result = await AuthService.RegisterAsync(registerModel);

            if (result.Success)
            {
                successMessage = result.Message ?? "Account created successfully!";
                registerModel = new RegisterRequest(); // Clear form
                StateHasChanged();

                // Redirect to login after 2 seconds
                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = result.Error ?? "Registration failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CheckUsername()
    {
        var username = registerModel.Username?.Trim() ?? "";
        if (username == lastCheckedUsername) return;
        lastCheckedUsername = username;

        if (username.Length < 3)
        {
            usernameValid = false;
            usernameMessage = "Username must be at least 3 characters";
            StateHasChanged();
            return;
        }

        isCheckingUsername = true;
        StateHasChanged();

        try
        {
            var exists = await AuthService.CheckUsernameExistsAsync(username);
            usernameValid = !exists;
            usernameMessage = exists ? "Username is already taken" : "Username is available!";
        }
        catch
        {
            usernameValid = null;
            usernameMessage = "Could not verify username";
        }
        finally
        {
            isCheckingUsername = false;
            StateHasChanged();
        }
    }

    private void TogglePassword() => showPassword = !showPassword;
    private void ToggleConfirmPassword() => showConfirmPassword = !showConfirmPassword;
}

