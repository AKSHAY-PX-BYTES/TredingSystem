@page "/fno"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IFnoApiService FnoApi
@inject NavigationManager Navigation
@inject IPlanAccessService PlanAccess

<PageTitle>F&O - Futures & Options</PageTitle>

<div class="fno-container">
    <div class="fno-header">
        <div class="fno-header-top">
            <h1>📊 Futures & Options</h1>
            <div class="fno-live-badge">
                <span class="live-dot"></span> LIVE
            </div>
        </div>
        <p class="fno-subtitle">AI-Powered F&O Analysis • Real-Time Signals • Stop Loss • Target • Confidence</p>
    </div>

    @if (isLoading)
    {
        <div class="fno-loading">
            <div class="spinner"></div>
            <p>Loading market data...</p>
        </div>
    }
    else if (indices == null || !indices.Any())
    {
        <div class="fno-empty">
            <p>Unable to load F&O data. Please try again later.</p>
            <button class="btn-refresh" @onclick="LoadData">🔄 Retry</button>
        </div>
    }
    else
    {
        <!-- Market Category Tabs -->
        <div class="market-tabs">
            <button class="tab-btn @(activeTab == "Indian" ? "active" : "")" @onclick='() => activeTab = "Indian"'>
                🇮🇳 Indian Indices
                <span class="tab-count">@IndianIndices.Count()</span>
            </button>
            <button class="tab-btn @(activeTab == "Global" ? "active" : "")" @onclick='() => activeTab = "Global"'>
                🌍 Global Indices
                <span class="tab-count">@GlobalIndices.Count()</span>
            </button>
        </div>

        <!-- Market Overview Stats -->
        <div class="market-overview">
            <div class="overview-stat">
                <span class="stat-label">Advancing</span>
                <span class="stat-value positive">@ActiveIndices.Count(i => i.Change >= 0)</span>
            </div>
            <div class="overview-stat">
                <span class="stat-label">Declining</span>
                <span class="stat-value negative">@ActiveIndices.Count(i => i.Change < 0)</span>
            </div>
            <div class="overview-stat">
                <span class="stat-label">Buy Signals</span>
                <span class="stat-value positive">@ActiveIndices.Count(i => i.Signal == "Buy")</span>
            </div>
            <div class="overview-stat">
                <span class="stat-label">Sell Signals</span>
                <span class="stat-value negative">@ActiveIndices.Count(i => i.Signal == "Sell")</span>
            </div>
        </div>

        <!-- Top Movers Cards -->
        <div class="top-movers-section">
            <h3>🔥 Top Movers</h3>
            <div class="fno-index-cards">
                @foreach (var index in ActiveIndices.OrderByDescending(i => Math.Abs(i.ChangePercent)).Take(4))
                {
                    <div class="fno-index-card @GetTrendClass(index.Trend)" @onclick="() => OpenIndex(index.Symbol)">
                        <div class="idx-card-header">
                            <span class="idx-name">@index.Name</span>
                            <span class="idx-signal @GetSignalClass(index.Signal)">@index.Signal</span>
                        </div>
                        <div class="idx-card-price">
                            <span class="idx-price">₹@index.LastPrice.ToString("N2")</span>
                            <span class="idx-change @(index.Change >= 0 ? "positive" : "negative")">
                                @(index.Change >= 0 ? "▲" : "▼") @Math.Abs(index.ChangePercent).ToString("N2")%
                            </span>
                        </div>
                        <div class="idx-card-meta">
                            <span>H: ₹@index.DayHigh.ToString("N2")</span>
                            <span>L: ₹@index.DayLow.ToString("N2")</span>
                            <span>OI: @FormatVolume(index.OpenInterest)</span>
                        </div>
                        <div class="idx-card-confidence">
                            <div class="confidence-bar">
                                <div class="confidence-fill @GetSignalClass(index.Signal)" style="width: @index.SignalConfidence%"></div>
                            </div>
                            <span>AI Confidence: @index.SignalConfidence.ToString("N0")%</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Filter and Grid -->
        <div class="fno-section">
            <h2>@(activeTab == "Indian" ? "🇮🇳 Indian" : "🌍 Global") Indices — Futures & Options</h2>
            <div class="fno-filter-bar">
                <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search index name..." class="fno-search" />
                <select @bind="filterSignal" class="fno-filter-select">
                    <option value="">All Signals</option>
                    <option value="Buy">🟢 Buy Only</option>
                    <option value="Sell">🔴 Sell Only</option>
                    <option value="Hold">🟡 Hold</option>
                </select>
                <select @bind="sortBy" class="fno-filter-select">
                    <option value="name">Sort: Name</option>
                    <option value="change">Sort: Change %</option>
                    <option value="oi">Sort: Open Interest</option>
                    <option value="confidence">Sort: AI Confidence</option>
                </select>
            </div>

            <div class="index-grid">
                @foreach (var item in SortedIndices)
                {
                    <div class="index-card @GetTrendClass(item.Trend)" @onclick="() => OpenIndex(item.Symbol)">
                        <div class="index-card-top">
                            <div class="index-card-info">
                                <span class="index-card-name">@item.Name</span>
                                <span class="index-card-symbol">@item.Symbol</span>
                            </div>
                            <span class="signal-badge @GetSignalClass(item.Signal)">@item.Signal</span>
                        </div>
                        <div class="index-card-price-row">
                            <span class="index-card-price">₹@item.LastPrice.ToString("N2")</span>
                            <span class="index-card-change @(item.Change >= 0 ? "positive" : "negative")">
                                @(item.Change >= 0 ? "+" : "")@item.ChangePercent.ToString("N2")%
                            </span>
                        </div>
                        <div class="index-card-footer">
                            <div class="mini-confidence">
                                <div class="mini-bar-bg">
                                    <div class="mini-bar @GetSignalClass(item.Signal)" style="width: @item.SignalConfidence%"></div>
                                </div>
                                <span>@item.SignalConfidence.ToString("N0")%</span>
                            </div>
                            <span class="trend-badge @GetTrendClass(item.Trend)">@item.Trend</span>
                        </div>
                        <div class="index-card-action">
                            <span>View F&O Chain →</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Models.FnoIndex>? indices;
    private bool isLoading = true;
    private string searchTerm = "";
    private string filterSignal = "";
    private string activeTab = "Indian";
    private string sortBy = "name";

    private IEnumerable<Models.FnoIndex> IndianIndices => (indices ?? new()).Where(i => i.Category == "Indian");
    private IEnumerable<Models.FnoIndex> GlobalIndices => (indices ?? new()).Where(i => i.Category == "Global");
    private IEnumerable<Models.FnoIndex> ActiveIndices => activeTab == "Indian" ? IndianIndices : GlobalIndices;

    private IEnumerable<Models.FnoIndex> FilteredIndices => ActiveIndices
        .Where(i => string.IsNullOrEmpty(searchTerm) || i.Symbol.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || i.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(i => string.IsNullOrEmpty(filterSignal) || i.Signal.Equals(filterSignal, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<Models.FnoIndex> SortedIndices => sortBy switch
    {
        "change" => FilteredIndices.OrderByDescending(i => Math.Abs(i.ChangePercent)),
        "oi" => FilteredIndices.OrderByDescending(i => i.OpenInterest),
        "confidence" => FilteredIndices.OrderByDescending(i => i.SignalConfidence),
        _ => FilteredIndices.OrderBy(i => i.Name)
    };

    protected override async Task OnInitializedAsync()
    {
        if (await PlanAccess.IsFreeUserAsync())
        {
            Navigation.NavigateTo("/plans");
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            indices = await FnoApi.GetIndicesAsync();
        }
        catch { indices = null; }
        isLoading = false;
    }

    private void OpenIndex(string symbol) => Navigation.NavigateTo($"/fno/{symbol}");

    private string GetSignalClass(string signal) => signal.ToLower() switch
    {
        "buy" => "signal-buy",
        "sell" => "signal-sell",
        _ => "signal-hold"
    };

    private string GetTrendClass(string trend) => trend.ToLower() switch
    {
        "bullish" => "trend-bullish",
        "bearish" => "trend-bearish",
        _ => "trend-neutral"
    };

    private string FormatVolume(decimal vol) => vol switch
    {
        >= 10000000 => $"{vol / 10000000:N2}Cr",
        >= 100000 => $"{vol / 100000:N2}L",
        >= 1000 => $"{vol / 1000:N1}K",
        _ => vol.ToString("N0")
    };

    private string FormatVolume(long vol) => FormatVolume((decimal)vol);
}

<style>
    .fno-container { max-width: 1440px; margin: 0 auto; padding: 24px 16px; }
    .fno-header { text-align: center; margin-bottom: 28px; }
    .fno-header-top { display: flex; align-items: center; justify-content: center; gap: 16px; }
    .fno-header h1 { font-size: 2rem; margin: 0; }
    .fno-live-badge { display: flex; align-items: center; gap: 6px; background: rgba(0,200,83,0.1); color: #00c853; font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 12px; }
    .live-dot { width: 8px; height: 8px; background: #00c853; border-radius: 50%; animation: pulse 1.5s infinite; }
    @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
    .fno-subtitle { color: var(--text-secondary); font-size: 0.95rem; margin-top: 6px; }
    .fno-loading { text-align: center; padding: 80px 0; }
    .fno-loading .spinner { width: 40px; height: 40px; border: 3px solid var(--border); border-top-color: var(--primary); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .market-tabs { display: flex; gap: 8px; margin-bottom: 24px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 6px; }
    .tab-btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 20px; border: none; background: transparent; color: var(--text-secondary); font-size: 1rem; font-weight: 600; border-radius: 8px; cursor: pointer; transition: all 0.2s; }
    .tab-btn:hover { background: var(--hover-bg); }
    .tab-btn.active { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(99,102,241,0.3); }
    .tab-count { font-size: 0.75rem; background: rgba(255,255,255,0.2); padding: 2px 8px; border-radius: 10px; }
    .tab-btn:not(.active) .tab-count { background: var(--border); }

    .market-overview { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
    .overview-stat { background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px; padding: 16px; text-align: center; }
    .stat-label { display: block; font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 4px; }
    .stat-value { font-size: 1.5rem; font-weight: 700; }

    .top-movers-section { margin-bottom: 32px; }
    .top-movers-section h3 { font-size: 1.1rem; margin-bottom: 14px; }
    .fno-index-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
    .fno-index-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px; padding: 20px; cursor: pointer; transition: all 0.2s; }
    .fno-index-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
    .fno-index-card.trend-bullish { border-left: 4px solid #00c853; }
    .fno-index-card.trend-bearish { border-left: 4px solid #ff1744; }
    .fno-index-card.trend-neutral { border-left: 4px solid #ffc107; }

    .idx-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .idx-name { font-size: 1rem; font-weight: 700; }
    .idx-signal { font-size: 0.7rem; font-weight: 700; padding: 3px 8px; border-radius: 10px; text-transform: uppercase; }
    .idx-card-price { margin-bottom: 8px; }
    .idx-price { font-size: 1.3rem; font-weight: 700; }
    .idx-change { font-size: 0.85rem; margin-left: 8px; font-weight: 600; }
    .idx-card-meta { display: flex; gap: 10px; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 10px; }
    .idx-card-confidence { font-size: 0.75rem; color: var(--text-secondary); }
    .confidence-bar { height: 5px; background: var(--border); border-radius: 3px; margin-bottom: 4px; overflow: hidden; }
    .confidence-fill { height: 100%; border-radius: 3px; transition: width 0.5s; }

    .positive { color: #00c853; }
    .negative { color: #ff1744; }
    .signal-buy { background: rgba(0,200,83,0.15); color: #00c853; }
    .signal-sell { background: rgba(255,23,68,0.15); color: #ff1744; }
    .signal-hold { background: rgba(255,193,7,0.15); color: #ffc107; }
    .confidence-fill.signal-buy { background: #00c853; }
    .confidence-fill.signal-sell { background: #ff1744; }
    .confidence-fill.signal-hold { background: #ffc107; }

    .fno-section h2 { font-size: 1.2rem; margin-bottom: 16px; }
    .fno-filter-bar { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .fno-search { flex: 1; min-width: 200px; padding: 10px 16px; border: 1px solid var(--border); border-radius: 8px; background: var(--card-bg); color: var(--text-primary); font-size: 0.9rem; }
    .fno-filter-select { padding: 10px 14px; border: 1px solid var(--border); border-radius: 8px; background: var(--card-bg); color: var(--text-primary); font-size: 0.85rem; }

    .index-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
    .index-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 18px; cursor: pointer; transition: all 0.2s; }
    .index-card:hover { border-color: var(--primary); box-shadow: 0 4px 16px rgba(99,102,241,0.1); transform: translateY(-2px); }
    .index-card.trend-bullish { border-top: 3px solid #00c853; }
    .index-card.trend-bearish { border-top: 3px solid #ff1744; }
    .index-card.trend-neutral { border-top: 3px solid #ffc107; }

    .index-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
    .index-card-info { display: flex; flex-direction: column; }
    .index-card-name { font-weight: 700; font-size: 0.95rem; }
    .index-card-symbol { font-size: 0.72rem; color: var(--text-secondary); margin-top: 2px; }
    .signal-badge { font-size: 0.7rem; font-weight: 700; padding: 3px 8px; border-radius: 8px; text-transform: uppercase; }

    .index-card-price-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: 12px; }
    .index-card-price { font-size: 1.2rem; font-weight: 700; }
    .index-card-change { font-size: 0.85rem; font-weight: 600; }

    .index-card-footer { display: flex; justify-content: space-between; align-items: center; }
    .mini-confidence { display: flex; align-items: center; gap: 6px; font-size: 0.75rem; color: var(--text-secondary); }
    .mini-bar-bg { width: 50px; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
    .mini-bar { height: 100%; border-radius: 2px; }
    .mini-bar.signal-buy { background: #00c853; }
    .mini-bar.signal-sell { background: #ff1744; }
    .mini-bar.signal-hold { background: #ffc107; }

    .trend-badge { font-size: 0.68rem; font-weight: 600; padding: 3px 8px; border-radius: 6px; }
    .trend-badge.trend-bullish { background: rgba(0,200,83,0.1); color: #00c853; }
    .trend-badge.trend-bearish { background: rgba(255,23,68,0.1); color: #ff1744; }
    .trend-badge.trend-neutral { background: rgba(255,193,7,0.1); color: #ffc107; }

    .index-card-action { margin-top: 12px; padding-top: 10px; border-top: 1px solid var(--border); text-align: center; font-size: 0.8rem; color: var(--primary); font-weight: 600; }

    .btn-refresh { padding: 10px 24px; border: none; background: var(--primary); color: white; border-radius: 8px; cursor: pointer; font-weight: 600; }
    .fno-empty { text-align: center; padding: 60px 0; }

    @@media (max-width: 1024px) {
        .fno-index-cards { grid-template-columns: repeat(2, 1fr); }
        .index-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 768px) {
        .fno-container { padding: 12px 8px; }
        .fno-header h1 { font-size: 1.4rem; }
        .fno-subtitle { font-size: 0.8rem; }
        .market-tabs { flex-direction: column; gap: 4px; padding: 4px; }
        .tab-btn { padding: 12px 14px; font-size: 0.9rem; }
        .market-overview { grid-template-columns: repeat(2, 1fr); gap: 8px; }
        .overview-stat { padding: 12px 8px; }
        .stat-value { font-size: 1.2rem; }
        .fno-index-cards { grid-template-columns: 1fr; gap: 10px; }
        .fno-index-card { padding: 16px; }
        .index-grid { grid-template-columns: 1fr; gap: 10px; }
        .index-card { padding: 14px; }
        .fno-filter-bar { flex-direction: column; }
        .fno-search { min-width: unset; width: 100%; }
        .fno-filter-select { width: 100%; }
        .top-movers-section h3 { font-size: 1rem; }
        .idx-price { font-size: 1.1rem; }
    }

    @@media (max-width: 380px) {
        .market-overview { grid-template-columns: repeat(2, 1fr); gap: 6px; }
        .stat-value { font-size: 1rem; }
        .stat-label { font-size: 0.65rem; }
        .idx-price { font-size: 1rem; }
        .index-card-price { font-size: 1rem; }
    }
</style>
