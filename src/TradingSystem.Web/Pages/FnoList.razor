@page "/fno"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IFnoApiService FnoApi
@inject NavigationManager Navigation

<PageTitle>F&O - Futures & Options</PageTitle>

<div class="fno-container">
    <div class="fno-header">
        <h1>📊 Futures & Options</h1>
        <p class="fno-subtitle">AI-Powered F&O Analysis with Real-Time Buy/Sell Signals</p>
    </div>

    @if (isLoading)
    {
        <div class="fno-loading">
            <div class="spinner"></div>
            <p>Loading F&O data...</p>
        </div>
    }
    else if (indices == null || !indices.Any())
    {
        <div class="fno-empty">
            <p>Unable to load F&O data. Please try again later.</p>
            <button class="btn-refresh" @onclick="LoadData">🔄 Retry</button>
        </div>
    }
    else
    {
        <!-- Index Summary Cards -->
        <div class="fno-index-cards">
            @foreach (var index in indices.Where(i => i.Symbol is "NIFTY50" or "BANKNIFTY" or "SENSEX"))
            {
                <div class="fno-index-card @GetTrendClass(index.Trend)" @onclick="() => OpenIndex(index.Symbol)">
                    <div class="idx-card-header">
                        <span class="idx-name">@index.Name</span>
                        <span class="idx-signal @GetSignalClass(index.Signal)">@index.Signal</span>
                    </div>
                    <div class="idx-card-price">
                        <span class="idx-price">₹@index.LastPrice.ToString("N2")</span>
                        <span class="idx-change @(index.Change >= 0 ? "positive" : "negative")">
                            @(index.Change >= 0 ? "+" : "")@index.Change.ToString("N2") (@index.ChangePercent.ToString("N2")%)
                        </span>
                    </div>
                    <div class="idx-card-meta">
                        <span>H: ₹@index.DayHigh.ToString("N2")</span>
                        <span>L: ₹@index.DayLow.ToString("N2")</span>
                        <span>OI: @FormatVolume(index.OpenInterest)</span>
                    </div>
                    <div class="idx-card-confidence">
                        <div class="confidence-bar">
                            <div class="confidence-fill @GetSignalClass(index.Signal)" style="width: @index.SignalConfidence%"></div>
                        </div>
                        <span>@index.SignalConfidence.ToString("N0")% confidence</span>
                    </div>
                </div>
            }
        </div>

        <!-- All F&O Instruments -->
        <div class="fno-section">
            <h2>All F&O Instruments</h2>
            <div class="fno-filter-bar">
                <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search symbol..." class="fno-search" />
                <select @bind="filterSignal" class="fno-filter-select">
                    <option value="">All Signals</option>
                    <option value="Buy">Buy Only</option>
                    <option value="Sell">Sell Only</option>
                    <option value="Hold">Hold</option>
                </select>
            </div>
            <div class="fno-table-wrapper">
                <table class="fno-table">
                    <thead>
                        <tr>
                            <th>Symbol</th>
                            <th>LTP</th>
                            <th>Change</th>
                            <th>Volume</th>
                            <th>Open Interest</th>
                            <th>Trend</th>
                            <th>AI Signal</th>
                            <th>Confidence</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredIndices)
                        {
                            <tr class="fno-row" @onclick="() => OpenIndex(item.Symbol)">
                                <td class="symbol-cell">
                                    <strong>@item.Symbol</strong>
                                    <small>@item.Name</small>
                                </td>
                                <td>₹@item.LastPrice.ToString("N2")</td>
                                <td class="@(item.Change >= 0 ? "positive" : "negative")">
                                    @(item.Change >= 0 ? "+" : "")@item.ChangePercent.ToString("N2")%
                                </td>
                                <td>@FormatVolume(item.Volume)</td>
                                <td>@FormatVolume(item.OpenInterest)</td>
                                <td>
                                    <span class="trend-badge @GetTrendClass(item.Trend)">@item.Trend</span>
                                </td>
                                <td>
                                    <span class="signal-badge @GetSignalClass(item.Signal)">@item.Signal</span>
                                </td>
                                <td>
                                    <div class="mini-confidence">
                                        <div class="mini-bar @GetSignalClass(item.Signal)" style="width: @item.SignalConfidence%"></div>
                                        <span>@item.SignalConfidence.ToString("N0")%</span>
                                    </div>
                                </td>
                                <td>
                                    <button class="btn-view" @onclick:stopPropagation="true" @onclick="() => OpenIndex(item.Symbol)">
                                        View Options →
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<Models.FnoIndex>? indices;
    private bool isLoading = true;
    private string searchTerm = "";
    private string filterSignal = "";

    private IEnumerable<Models.FnoIndex> FilteredIndices => (indices ?? new())
        .Where(i => string.IsNullOrEmpty(searchTerm) || i.Symbol.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || i.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(i => string.IsNullOrEmpty(filterSignal) || i.Signal.Equals(filterSignal, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            indices = await FnoApi.GetIndicesAsync();
        }
        catch { indices = null; }
        isLoading = false;
    }

    private void OpenIndex(string symbol) => Navigation.NavigateTo($"/fno/{symbol}");

    private string GetSignalClass(string signal) => signal.ToLower() switch
    {
        "buy" => "signal-buy",
        "sell" => "signal-sell",
        _ => "signal-hold"
    };

    private string GetTrendClass(string trend) => trend.ToLower() switch
    {
        "bullish" => "trend-bullish",
        "bearish" => "trend-bearish",
        _ => "trend-neutral"
    };

    private string FormatVolume(decimal vol) => vol switch
    {
        >= 10000000 => $"{vol / 10000000:N2}Cr",
        >= 100000 => $"{vol / 100000:N2}L",
        >= 1000 => $"{vol / 1000:N1}K",
        _ => vol.ToString("N0")
    };

    private string FormatVolume(long vol) => FormatVolume((decimal)vol);
}

<style>
    .fno-container { max-width: 1400px; margin: 0 auto; padding: 24px 16px; }
    .fno-header { text-align: center; margin-bottom: 32px; }
    .fno-header h1 { font-size: 2rem; margin-bottom: 4px; }
    .fno-subtitle { color: var(--text-secondary); font-size: 1rem; }
    .fno-loading { text-align: center; padding: 80px 0; }
    .fno-loading .spinner { width: 40px; height: 40px; border: 3px solid var(--border); border-top-color: var(--primary); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .fno-index-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .fno-index-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 24px; cursor: pointer; transition: all 0.2s; }
    .fno-index-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
    .fno-index-card.trend-bullish { border-left: 4px solid #00c853; }
    .fno-index-card.trend-bearish { border-left: 4px solid #ff1744; }
    .fno-index-card.trend-neutral { border-left: 4px solid #ffc107; }

    .idx-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .idx-name { font-size: 1.1rem; font-weight: 700; }
    .idx-signal { font-size: 0.75rem; font-weight: 700; padding: 4px 10px; border-radius: 12px; text-transform: uppercase; }
    .idx-card-price { margin-bottom: 8px; }
    .idx-price { font-size: 1.5rem; font-weight: 700; }
    .idx-change { font-size: 0.9rem; margin-left: 8px; }
    .idx-card-meta { display: flex; gap: 12px; font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 12px; }
    .idx-card-confidence { font-size: 0.8rem; color: var(--text-secondary); }
    .confidence-bar { height: 6px; background: var(--border); border-radius: 3px; margin-bottom: 4px; overflow: hidden; }
    .confidence-fill { height: 100%; border-radius: 3px; transition: width 0.5s; }

    .positive { color: #00c853; }
    .negative { color: #ff1744; }
    .signal-buy { background: rgba(0,200,83,0.15); color: #00c853; }
    .signal-sell { background: rgba(255,23,68,0.15); color: #ff1744; }
    .signal-hold { background: rgba(255,193,7,0.15); color: #ffc107; }
    .confidence-fill.signal-buy { background: #00c853; }
    .confidence-fill.signal-sell { background: #ff1744; }
    .confidence-fill.signal-hold { background: #ffc107; }

    .fno-section h2 { font-size: 1.3rem; margin-bottom: 16px; }
    .fno-filter-bar { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
    .fno-search { flex: 1; min-width: 200px; padding: 10px 16px; border: 1px solid var(--border); border-radius: 8px; background: var(--card-bg); color: var(--text-primary); font-size: 0.9rem; }
    .fno-filter-select { padding: 10px 16px; border: 1px solid var(--border); border-radius: 8px; background: var(--card-bg); color: var(--text-primary); }

    .fno-table-wrapper { overflow-x: auto; border-radius: 12px; border: 1px solid var(--border); }
    .fno-table { width: 100%; border-collapse: collapse; }
    .fno-table th { padding: 14px 16px; text-align: left; font-size: 0.8rem; text-transform: uppercase; color: var(--text-secondary); background: var(--card-bg); border-bottom: 1px solid var(--border); }
    .fno-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); }
    .fno-row { cursor: pointer; transition: background 0.15s; }
    .fno-row:hover { background: var(--hover-bg); }
    .symbol-cell { display: flex; flex-direction: column; }
    .symbol-cell small { color: var(--text-secondary); font-size: 0.75rem; }

    .trend-badge, .signal-badge { font-size: 0.75rem; font-weight: 600; padding: 4px 8px; border-radius: 6px; }
    .trend-badge.trend-bullish { background: rgba(0,200,83,0.1); color: #00c853; }
    .trend-badge.trend-bearish { background: rgba(255,23,68,0.1); color: #ff1744; }
    .trend-badge.trend-neutral { background: rgba(255,193,7,0.1); color: #ffc107; }

    .mini-confidence { display: flex; align-items: center; gap: 6px; }
    .mini-bar { height: 4px; border-radius: 2px; min-width: 40px; }
    .mini-bar.signal-buy { background: #00c853; }
    .mini-bar.signal-sell { background: #ff1744; }
    .mini-bar.signal-hold { background: #ffc107; }

    .btn-view { padding: 6px 14px; border: 1px solid var(--primary); color: var(--primary); border-radius: 6px; background: transparent; cursor: pointer; font-size: 0.8rem; font-weight: 600; transition: all 0.2s; }
    .btn-view:hover { background: var(--primary); color: white; }
    .btn-refresh { padding: 10px 24px; border: none; background: var(--primary); color: white; border-radius: 8px; cursor: pointer; font-weight: 600; }
</style>
