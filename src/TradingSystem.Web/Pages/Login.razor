@page "/login"
@layout LoginLayout
@using TradingSystem.Web.Models
@using TradingSystem.Web.Services
@inject IAuthService AuthService
@inject IFeatureFlagService FeatureFlagService
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Login - Trading System</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">
                <span class="logo-icon">📈</span>
                <h1>Trading System</h1>
                <p class="login-subtitle">AI-Based Strategy Predictor</p>
            </div>
        </div>

        <div class="login-body">
            @if (showTimeoutMessage)
            {
                <div class="login-warning">
                    <span class="warning-icon">⏰</span>
                    <span>You were logged out due to inactivity</span>
                </div>
            }

            @if (showExpiredMessage)
            {
                <div class="login-warning">
                    <span class="warning-icon">🔑</span>
                    <span>Your session token expired. Please login again.</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="login-error">
                    <span class="error-icon">⚠️</span>
                    <span>@errorMessage</span>
                </div>
            }

            <div class="login-form">
                <div class="form-group">
                    <label for="username">
                        <span class="field-icon">👤</span> Username
                    </label>
                    <div class="username-wrapper">
                        <input id="username" type="text" @bind="loginModel.Username" @bind:event="oninput"
                               @onfocusout="CheckUsername"
                               class="form-input @usernameInputClass" placeholder="Enter your username"
                               disabled="@isLoading" />
                        @if (isCheckingUsername)
                        {
                            <span class="username-status checking">⏳</span>
                        }
                        else if (usernameValid == true)
                        {
                            <span class="username-status valid">✅</span>
                        }
                        else if (usernameValid == false)
                        {
                            <span class="username-status invalid">❌</span>
                        }
                    </div>
                    @if (usernameValid == false && !string.IsNullOrEmpty(usernameMessage))
                    {
                        <div class="field-msg field-error">@usernameMessage</div>
                    }
                    @if (usernameValid == true)
                    {
                        <div class="field-msg field-success">@usernameMessage</div>
                    }
                </div>

                <div class="form-group @(usernameValid != true ? "field-locked" : "")">
                    <label for="password">
                        <span class="field-icon">🔒</span> Password
                        @if (usernameValid != true)
                        {
                            <span class="lock-hint">— Enter valid username first</span>
                        }
                    </label>
                    <div class="password-wrapper">
                        <input id="password" type="@(showPassword ? "text" : "password")"
                               @bind="loginModel.Password" @bind:event="oninput"
                               class="form-input" placeholder="Enter your password"
                               disabled="@(isLoading || usernameValid != true)" />
                        <button type="button" class="toggle-password" @onclick="TogglePassword"
                                tabindex="-1" disabled="@(usernameValid != true)">
                            @(showPassword ? "🙈" : "👁️")
                        </button>
                    </div>

                    @if (usernameValid == true && !string.IsNullOrWhiteSpace(loginModel.Password))
                    {
                        <div class="pwd-policy">
                            <div class="pwd-policy-title">Password must contain:</div>
                            <div class="pwd-rule @(HasMinLength ? "pass" : "fail")">
                                <span class="pwd-icon">@(HasMinLength ? "✅" : "❌")</span>
                                At least 8 characters
                            </div>
                            <div class="pwd-rule @(HasLowercase ? "pass" : "fail")">
                                <span class="pwd-icon">@(HasLowercase ? "✅" : "❌")</span>
                                Lower case letters (a-z)
                            </div>
                            <div class="pwd-rule @(HasUppercase ? "pass" : "fail")">
                                <span class="pwd-icon">@(HasUppercase ? "✅" : "❌")</span>
                                Upper case letters (A-Z)
                            </div>
                            <div class="pwd-rule @(HasDigit ? "pass" : "fail")">
                                <span class="pwd-icon">@(HasDigit ? "✅" : "❌")</span>
                                Numbers (0-9)
                            </div>
                            <div class="pwd-rule @(HasSpecial ? "pass" : "fail")">
                                <span class="pwd-icon">@(HasSpecial ? "✅" : "❌")</span>
                                Special characters (e.g. !@@#$%^&amp;)
                            </div>
                            <div class="pwd-rule @(NoRepeatingChars ? "pass" : "fail")">
                                <span class="pwd-icon">@(NoRepeatingChars ? "✅" : "❌")</span>
                                No more than 2 identical characters in a row
                            </div>
                        </div>
                    }
                </div>

                <button type="button" class="login-btn" @onclick="HandleLogin" disabled="@(!CanSubmit)">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <span>🔐 Sign In</span>
                    }
                </button>
            </div>

            @if (signupEnabled)
            {
                <div class="register-link" style="text-align: center; margin-top: 1.5rem;">
                    <span style="color: var(--text-muted);">Don't have an account?</span>
                    <a href="/register" style="color: var(--groww-green); font-weight: 600; margin-left: 0.5rem;">Sign Up</a>
                </div>
            }
        </div>

        <div class="login-footer">
            <p>© 2026 Trading System • Powered by AI & ML.NET</p>
            <div class="developer-info" style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-color);">
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;">
                    <strong style="color: var(--groww-green);">Designed & Developed by Akshay Patil</strong>
                </p>
                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; font-size: 0.8rem;">
                    <a href="https://wa.me/919850706564" target="_blank" rel="noopener" style="color: #25D366; text-decoration: none;">
                        📱 WhatsApp: +91 9850706564
                    </a>
                    <a href="mailto:apakshay582@gmail.com" style="color: var(--groww-green); text-decoration: none;">
                        ✉️ apakshay582@gmail.com
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="login-features">
        <div class="feature-item">
            <span class="feature-icon">🤖</span>
            <h3>AI Predictions</h3>
            <p>ML-powered stock price predictions with confidence scoring</p>
        </div>
        <div class="feature-item">
            <span class="feature-icon">📊</span>
            <h3>Technical Analysis</h3>
            <p>Real-time indicators: SMA, EMA, RSI, MACD, Bollinger Bands</p>
        </div>
        <div class="feature-item">
            <span class="feature-icon">📰</span>
            <h3>Sentiment Analysis</h3>
            <p>News-based sentiment scoring for informed trading decisions</p>
        </div>
        <div class="feature-item">
            <span class="feature-icon">🔄</span>
            <h3>Backtesting</h3>
            <p>Validate strategies against historical data with equity curves</p>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool isLoading;
    private bool showPassword;
    private bool showTimeoutMessage;
    private bool showExpiredMessage;
    private bool signupEnabled = true;

    // Username validation
    private bool? usernameValid;
    private string? usernameMessage;
    private bool isCheckingUsername;
    private string lastCheckedUsername = string.Empty;

    private string usernameInputClass => usernameValid switch
    {
        true => "input-valid",
        false => "input-invalid",
        _ => ""
    };

    // Password policy checks
    private string pwd => loginModel.Password ?? string.Empty;
    private bool HasMinLength => pwd.Length >= 8;
    private bool HasLowercase => pwd.Any(char.IsLower);
    private bool HasUppercase => pwd.Any(char.IsUpper);
    private bool HasDigit => pwd.Any(char.IsDigit);
    private bool HasSpecial => pwd.Any(c => "!@#$%^&*()_+-=[]{}|;':\",./<>?`~".Contains(c));
    private bool NoRepeatingChars => !HasThreeConsecutiveIdentical(pwd);
    private bool AllPasswordRulesPass => HasMinLength && HasLowercase && HasUppercase && HasDigit && HasSpecial && NoRepeatingChars;
    private bool CanSubmit => usernameValid == true && AllPasswordRulesPass && !isLoading && !string.IsNullOrWhiteSpace(loginModel.Password);

    private static bool HasThreeConsecutiveIdentical(string s)
    {
        for (int i = 2; i < s.Length; i++)
        {
            if (s[i] == s[i - 1] && s[i] == s[i - 2]) return true;
        }
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await FeatureFlagService.LoadFlagsAsync();
        signupEnabled = FeatureFlagService.IsEnabled("signup");

        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        showTimeoutMessage = query["reason"] == "timeout";
        showExpiredMessage = query["reason"] == "expired";

        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (isAuthenticated)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    private async Task CheckUsername()
    {
        var username = loginModel.Username?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(username))
        {
            usernameValid = null;
            usernameMessage = null;
            return;
        }

        if (username == lastCheckedUsername && usernameValid != null)
            return;

        isCheckingUsername = true;
        usernameValid = null;
        usernameMessage = null;
        StateHasChanged();

        try
        {
            var exists = await AuthService.CheckUsernameExistsAsync(username);
            lastCheckedUsername = username;

            if (exists)
            {
                usernameValid = true;
                usernameMessage = $"✓ Username \"{username}\" found";
            }
            else
            {
                usernameValid = false;
                usernameMessage = $"Username \"{username}\" does not exist";
            }
        }
        catch
        {
            usernameValid = false;
            usernameMessage = "Unable to verify username";
        }
        finally
        {
            isCheckingUsername = false;
            StateHasChanged();
        }
    }

    private async Task HandleLogin()
    {
        if (!CanSubmit) return;

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await AuthService.LoginAsync(loginModel);

            if (result.Success)
            {
                AuthStateProvider.NotifyAuthStateChanged();
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                errorMessage = result.Error ?? "Login failed. Please check your credentials.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }
}
