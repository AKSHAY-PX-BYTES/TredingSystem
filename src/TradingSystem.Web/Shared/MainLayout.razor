@inherits LayoutComponentBase
@implements IDisposable
@inject IAuthService AuthService
@inject ICurrencyService CurrencyService
@inject IThemeService ThemeService
@inject IFeatureFlagService FeatureFlagService
@inject INotificationApiService NotificationApi
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="groww-app" data-theme="@ThemeService.CurrentTheme">
    <!-- Top Navbar (slim) -->
    <header class="groww-navbar">
        <div class="navbar-inner">
            <div class="navbar-left">
                <button class="menu-toggle" @onclick="ToggleSidebar" title="Menu">
                    <span class="hamburger-icon @(sidebarOpen ? "open" : "")">
                        <span></span><span></span><span></span>
                    </span>
                </button>
                <NavLink class="navbar-brand" href="" Match="NavLinkMatch.All">
                    <span class="brand-icon">📈</span>
                    <span class="brand-text">AI Trader</span>
                </NavLink>
            </div>
            <div class="navbar-right">
                @if (isAdmin)
                {
                    <NavLink class="admin-nav-link" href="admin">⚙️</NavLink>
                }
                <button class="theme-toggle" @onclick="ToggleTheme" title="Toggle Theme">
                    @(ThemeService.IsDarkMode ? "☀️" : "🌙")
                </button>
                @if (IsFeatureVisible("currency_change"))
                {
                    <select class="currency-pill" value="@CurrencyService.CurrentCurrencyCode"
                            @onchange="OnCurrencyChanged">
                        @foreach (var currency in CurrencyService.AvailableCurrencies)
                        {
                            <option value="@currency.Code">@currency.Symbol @currency.Code</option>
                        }
                    </select>
                }
                @if (IsFeatureVisible("notifications"))
                {
                    <NavLink class="notif-btn" href="notifications" title="Notifications">
                        🔔 @if(unreadNotifications > 0){<span class="nav-badge">@unreadNotifications</span>}
                    </NavLink>
                }
                <AuthorizeView>
                    <Authorized>
                        <div class="user-pill" @onclick="ToggleSidebar">
                            <span class="user-avatar-sm">@(context.User.Identity?.Name?[0].ToString().ToUpper() ?? "U")</span>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <!-- Sidebar Overlay -->
    @if (sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
    }

    <!-- Slide-out Sidebar -->
    <aside class="sidebar @(sidebarOpen ? "open" : "")">
        <div class="sidebar-header">
            <AuthorizeView>
                <Authorized>
                    <div class="sidebar-user">
                        <div class="sidebar-avatar">@(context.User.Identity?.Name?[0].ToString().ToUpper() ?? "U")</div>
                        <div class="sidebar-user-info">
                            <span class="sidebar-username">@context.User.Identity?.Name</span>
                            <span class="plan-badge plan-badge-@(userPlan.ToLower())">@GetPlanBadge(userPlan)</span>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <nav class="sidebar-nav">
            <div class="sidebar-section-label">Main</div>
            <NavLink class="sidebar-link" href="" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                <span class="sidebar-icon">🏠</span><span>Explore</span>
            </NavLink>
            @if (IsFeatureVisible("markets"))
            {
                <NavLink class="sidebar-link" href="markets" @onclick="CloseSidebar">
                    <span class="sidebar-icon">📊</span><span>Markets</span>
                </NavLink>
            }
            <NavLink class="sidebar-link" href="fno" @onclick="CloseSidebar">
                <span class="sidebar-icon">📉</span><span>F&O Options</span>
            </NavLink>
            @if (IsFeatureVisible("watchlist"))
            {
                <NavLink class="sidebar-link" href="watchlist" @onclick="CloseSidebar">
                    <span class="sidebar-icon">⭐</span><span>Watchlist</span>
                </NavLink>
            }

            <div class="sidebar-section-label">Analysis</div>
            @if (IsFeatureVisible("charts"))
            {
                <NavLink class="sidebar-link" href="charts" @onclick="CloseSidebar">
                    <span class="sidebar-icon">📈</span><span>Charts</span>
                </NavLink>
            }
            @if (IsFeatureVisible("compare"))
            {
                <NavLink class="sidebar-link" href="compare" @onclick="CloseSidebar">
                    <span class="sidebar-icon">⚖️</span><span>Compare</span>
                </NavLink>
            }
            @if (IsFeatureVisible("backtest"))
            {
                <NavLink class="sidebar-link" href="backtest" @onclick="CloseSidebar">
                    <span class="sidebar-icon">🧪</span><span>Backtest</span>
                </NavLink>
            }

            <div class="sidebar-section-label">AI & Signals</div>
            @if (IsFeatureVisible("ai_signals"))
            {
                <NavLink class="sidebar-link" href="signals" @onclick="CloseSidebar">
                    <span class="sidebar-icon">�</span><span>AI Signals</span>
                </NavLink>
            }
            @if (IsFeatureVisible("ai_chat"))
            {
                <NavLink class="sidebar-link" href="chat" @onclick="CloseSidebar">
                    <span class="sidebar-icon">💬</span><span>AI Chat</span>
                </NavLink>
            }
            <NavLink class="sidebar-link" href="agents" @onclick="CloseSidebar">
                <span class="sidebar-icon">🤖</span><span>AI Agents</span>
            </NavLink>

            <div class="sidebar-section-label">More</div>
            @if (IsFeatureVisible("news"))
            {
                <NavLink class="sidebar-link" href="news" @onclick="CloseSidebar">
                    <span class="sidebar-icon">📰</span><span>News</span>
                </NavLink>
            }
            @if (IsFeatureVisible("notifications"))
            {
                <NavLink class="sidebar-link" href="notifications" @onclick="CloseSidebar">
                    <span class="sidebar-icon">🔔</span><span>Notifications @if(unreadNotifications > 0){<span class="nav-badge">@unreadNotifications</span>}</span>
                </NavLink>
            }
            <NavLink class="sidebar-link" href="plans" @onclick="CloseSidebar">
                <span class="sidebar-icon">🏷️</span><span>Plans & Pricing</span>
            </NavLink>
            @if (isAdmin)
            {
                <NavLink class="sidebar-link" href="admin" @onclick="CloseSidebar">
                    <span class="sidebar-icon">⚙️</span><span>Admin Panel</span>
                </NavLink>
            }
        </nav>

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <button class="sidebar-link sidebar-btn" @onclick="() => { showChangePassword = true; CloseSidebar(); }">
                        <span class="sidebar-icon">🔑</span><span>Change Password</span>
                    </button>
                    <button class="sidebar-link sidebar-btn sidebar-logout" @onclick="HandleLogout">
                        <span class="sidebar-icon">🚪</span><span>Sign Out</span>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="groww-main">
        @Body
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-bottom-nav">
        <NavLink class="mobile-nav-item" href="" Match="NavLinkMatch.All">
            <span>🏠</span><span>Explore</span>
        </NavLink>
        @if (IsFeatureVisible("markets"))
        {
            <NavLink class="mobile-nav-item" href="markets">
                <span>📊</span><span>Markets</span>
            </NavLink>
        }
        <NavLink class="mobile-nav-item" href="fno">
            <span>📉</span><span>F&O</span>
        </NavLink>
        @if (IsFeatureVisible("watchlist"))
        {
            <NavLink class="mobile-nav-item" href="watchlist">
                <span>⭐</span><span>Watchlist</span>
            </NavLink>
        }
        <button class="mobile-nav-item" @onclick="ToggleSidebar">
            <span>☰</span><span>Menu</span>
        </button>
    </nav>

    <!-- Change Password Modal -->
    @if (showChangePassword)
    {
        <div class="modal-overlay" @onclick="() => showChangePassword = false">
            <div class="modal-content change-pwd-modal" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>🔑 Change Password</h3>
                    <button class="modal-close" @onclick="() => showChangePassword = false">✕</button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(pwdSuccessMessage))
                    {
                        <div class="pwd-success">✅ @pwdSuccessMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(pwdErrorMessage))
                    {
                        <div class="pwd-error">❌ @pwdErrorMessage</div>
                    }
                    <div class="form-group">
                        <label>Current Password</label>
                        <input type="password" @bind="currentPassword" placeholder="Enter current password" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" @bind="newPassword" @bind:event="oninput" placeholder="Enter new password" class="form-input" />
                        @if (!string.IsNullOrWhiteSpace(newPassword))
                        {
                            <div class="pwd-policy">
                                <div class="pwd-policy-title">Password must contain:</div>
                                <div class="pwd-rule @(CpHasMinLength ? "pass" : "fail")">
                                    <span class="pwd-icon">@(CpHasMinLength ? "✅" : "❌")</span> At least 8 characters
                                </div>
                                <div class="pwd-rule @(CpHasLowercase ? "pass" : "fail")">
                                    <span class="pwd-icon">@(CpHasLowercase ? "✅" : "❌")</span> Lower case letters (a-z)
                                </div>
                                <div class="pwd-rule @(CpHasUppercase ? "pass" : "fail")">
                                    <span class="pwd-icon">@(CpHasUppercase ? "✅" : "❌")</span> Upper case letters (A-Z)
                                </div>
                                <div class="pwd-rule @(CpHasDigit ? "pass" : "fail")">
                                    <span class="pwd-icon">@(CpHasDigit ? "✅" : "❌")</span> Numbers (0-9)
                                </div>
                                <div class="pwd-rule @(CpHasSpecial ? "pass" : "fail")">
                                    <span class="pwd-icon">@(CpHasSpecial ? "✅" : "❌")</span> Special characters (e.g. !@@#$%^&amp;)
                                </div>
                                <div class="pwd-rule @(CpNoRepeatingChars ? "pass" : "fail")">
                                    <span class="pwd-icon">@(CpNoRepeatingChars ? "✅" : "❌")</span> No more than 2 identical characters in a row
                                </div>
                            </div>
                        }
                    </div>
                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <input type="password" @bind="confirmNewPassword" @bind:event="oninput" placeholder="Confirm new password" class="form-input" />
                        @if (!string.IsNullOrWhiteSpace(confirmNewPassword))
                        {
                            <div class="field-msg @(newPassword == confirmNewPassword ? "field-success" : "field-error")">
                                @(newPassword == confirmNewPassword ? "✅ Passwords match" : "❌ Passwords do not match")
                            </div>
                        }
                    </div>
                    <button class="pwd-submit-btn" @onclick="HandleChangePassword" disabled="@(!CpCanSubmit)">
                        @if (isChangingPassword) { <span class="loading-spinner" style="width:14px;height:14px;border-width:2px;"></span> }
                        else { <span>Change Password</span> }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private const int IdleTimeoutMinutes = 10;
    private bool isAdmin = false;
    private string userPlan = "Basic";
    private bool sidebarOpen = false;

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar() => sidebarOpen = false;

    // Change password state
    private bool showChangePassword = false;
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmNewPassword = string.Empty;
    private string? pwdErrorMessage;
    private string? pwdSuccessMessage;
    private bool isChangingPassword = false;

    // Change password policy checks
    private bool CpHasMinLength => newPassword.Length >= 8;
    private bool CpHasLowercase => newPassword.Any(char.IsLower);
    private bool CpHasUppercase => newPassword.Any(char.IsUpper);
    private bool CpHasDigit => newPassword.Any(char.IsDigit);
    private bool CpHasSpecial => newPassword.Any(c => "!@#$%^&*()_+-=[]{}|;':\",./<>?`~".Contains(c));
    private bool CpNoRepeatingChars => !CpHasThreeConsecutive(newPassword);
    private bool CpAllRulesPass => CpHasMinLength && CpHasLowercase && CpHasUppercase && CpHasDigit && CpHasSpecial && CpNoRepeatingChars;
    private bool CpCanSubmit => !isChangingPassword && !string.IsNullOrWhiteSpace(currentPassword) && CpAllRulesPass && newPassword == confirmNewPassword;

    private static bool CpHasThreeConsecutive(string s)
    {
        for (int i = 2; i < s.Length; i++)
        {
            if (s[i] == s[i - 1] && s[i] == s[i - 2]) return true;
        }
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await CurrencyService.LoadCurrenciesAsync();
        await ThemeService.InitializeAsync();
        await FeatureFlagService.LoadFlagsAsync();
        CurrencyService.OnCurrencyChanged += StateHasChanged;
        ThemeService.OnThemeChanged += StateHasChanged;
        FeatureFlagService.OnFlagsChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Check if user is authenticated before initializing idle timeout
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            
            if (isAuthenticated)
            {
                // Initialize idle timeout tracker ONLY if authenticated
                _dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("IdleTimeoutManager.init", _dotNetRef, IdleTimeoutMinutes);
            }

            // Check if user is admin
            try
            {
                var userJson = await JS.InvokeAsync<string?>("localStorage.getItem", "authUser");
                if (!string.IsNullOrEmpty(userJson))
                {
                    var user = System.Text.Json.JsonSerializer.Deserialize<TradingSystem.Web.Models.UserInfo>(userJson,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    isAdmin = user?.Role == "Admin";
                    userPlan = user?.Plan ?? "Free";

                    // Load unread notifications count
                    try { unreadNotifications = await NotificationApi.GetUnreadCountAsync(); } catch { }

                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    [JSInvokable]
    public async Task OnIdleTimeout()
    {
        // Auto logout due to inactivity
        await AuthService.LogoutAsync();
        await JS.InvokeVoidAsync("IdleTimeoutManager.stop");
        Navigation.NavigateTo("/login?reason=timeout", forceLoad: true);
    }

    [JSInvokable]
    public async Task OnSessionRefresh()
    {
        // User chose to continue — refresh the token
        var success = await AuthService.RefreshTokenAsync();
        if (success)
        {
            // Reset the idle timer too
            await JS.InvokeVoidAsync("IdleTimeoutManager.resetTimer");
        }
        else
        {
            // Refresh failed, force logout
            await AuthService.LogoutAsync();
            await JS.InvokeVoidAsync("IdleTimeoutManager.stop");
            Navigation.NavigateTo("/login?reason=expired", forceLoad: true);
        }
    }

    [JSInvokable]
    public async Task OnSessionLogout()
    {
        // User chose to logout
        await AuthService.LogoutAsync();
        await JS.InvokeVoidAsync("IdleTimeoutManager.stop");
        Navigation.NavigateTo("/login?reason=expired", forceLoad: true);
    }

    private async Task OnCurrencyChanged(ChangeEventArgs e)
    {
        if (e.Value is string currencyCode)
        {
            await CurrencyService.SetCurrencyAsync(currencyCode);
        }
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
    }

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("IdleTimeoutManager.stop");
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private async Task HandleChangePassword()
    {
        pwdErrorMessage = null;
        pwdSuccessMessage = null;

        if (!CpCanSubmit) return;

        isChangingPassword = true;
        StateHasChanged();

        var result = await AuthService.ChangePasswordAsync(new TradingSystem.Web.Models.ChangePasswordRequest
        {
            CurrentPassword = currentPassword,
            NewPassword = newPassword,
            ConfirmNewPassword = confirmNewPassword
        });

        isChangingPassword = false;

        if (result.Success)
        {
            pwdSuccessMessage = result.Message ?? "Password changed successfully!";
            currentPassword = string.Empty;
            newPassword = string.Empty;
            confirmNewPassword = string.Empty;
        }
        else
        {
            pwdErrorMessage = result.Error ?? "Failed to change password";
        }
    }

    private static string GetPlanBadge(string plan) => plan switch
    {
        "Enterprise" => "🏢 ENTERPRISE",
        "Premium" => "� PREMIUM",
        "Pro" => "⚡ PRO",
        _ => "🆓 FREE"
    };

    private int unreadNotifications = 0;

    public void Dispose()
    {
        CurrencyService.OnCurrencyChanged -= StateHasChanged;
        ThemeService.OnThemeChanged -= StateHasChanged;
        FeatureFlagService.OnFlagsChanged -= StateHasChanged;
        _dotNetRef?.Dispose();
    }

    private bool IsFeatureVisible(string featureKey)
    {
        // Admin always sees everything
        return isAdmin || FeatureFlagService.IsEnabled(featureKey);
    }
}
