# ====================================================================
# TradingSystem E2E — Environment Configuration
# Copy this file to ".env" and fill in the values.
# ====================================================================

# --- Target application under test ---
# Frontend (Blazor WASM) base URL
BASE_URL=https://tredingsystem-31vm.onrender.com
# Backend API base URL (used by API integration tests)
API_BASE_URL=https://tredingsystem-api.onrender.com

# --- Environment name shown in reports (local | staging | production) ---
TEST_ENV=production

# --- Test user credentials (use a dedicated, disposable test account) ---
TEST_USERNAME=
TEST_PASSWORD=

# --- Admin credentials (optional; enables admin-only tests) ---
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Execution tuning ---
# Number of parallel workers (leave blank for Playwright default)
WORKERS=
# Per-test timeout in milliseconds
TEST_TIMEOUT=60000
# Retries on failure
RETRIES=1

# ====================================================================
# Email reporting (SMTP). Used by scripts/send-report-email.ts
# ====================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TradingSystem QA <qa@tredingsystem.com>"
# Comma-separated list of recipients
EMAIL_TO=
EMAIL_SUBJECT_PREFIX=[TradingSystem E2E]
